+def select_coupling_trace_loop_aggressive_relative_frontier_events(
+    context: CouplingNucleusContext,
+    *,
+    seed_events: Sequence[NucleusClosureEvent] = (),
+    baseline_fraction: float = AGGRESSIVE_RELATIVE_FRONTIER_BASELINE_FRACTION,
+    min_growth_ratio: float = AGGRESSIVE_RELATIVE_FRONTIER_MIN_GROWTH_RATIO,
+) -> tuple[NucleusClosureEvent, ...]:
+    """Open the broad candidate pool using a row-local relative baseline.
+
+    This is the Phase-3 aggressive frontier probe.  It intentionally does not
+    look for an internal gap and it does not restrict itself to the older
+    competitive-event pool.  For each row, the seed frontier supplies a native-
+    free identity baseline.  Any broad candidate whose generation score is at
+    least ``baseline_fraction`` of that baseline is promoted, but only when the
+    resulting row frontier grows by more than ``min_growth_ratio``.  Otherwise
+    the original seed frontier is kept.
+
+    The score is the existing candidate-generation acceptance proxy derived
+    from external-coupling coverage, sequence/closure support, and seed
+    continuation.  Native contact labels and coordinate truth are not read by
+    this selector.
+    """
+    if not seed_events:
+        seed_events = select_coupling_trace_loop_events(context)
+    seed_by_row = _events_by_row(seed_events)
+    candidate_by_row = _events_by_row(context.physical_context.candidate_events)
+    constraints_by_row = context.coupling_dataset.constraints_by_row_id()
+    selected: list[NucleusClosureEvent] = []
+    for row in context.rows:
+        row_seed_events = tuple(seed_by_row.get(row.row_id, ()))
+        if not row_seed_events:
+            continue
+        row_constraint_map = {
+            constraint.pair(): constraint
+            for constraint in constraints_by_row.get(row.row_id, ())
+        }
+        seed_scores = [
+            float(
+                _self_deciding_frontier_generation_score(
+                    seed,
+                    row_constraints=row_constraint_map,
+                    seed_events=(),
+                )["self_deciding_frontier_generation_score"]
+            )
+            for seed in row_seed_events
+        ]
+        baseline = _median_positive(seed_scores)
+        if baseline <= 0.0:
+            selected.extend(row_seed_events)
+            continue
+        threshold = baseline_fraction * baseline
+        row_frontier: list[tuple[float, NucleusClosureEvent]] = []
+        for event in candidate_by_row.get(row.row_id, ()):
+            score_row = _self_deciding_frontier_generation_score(
+                event,
+                row_constraints=row_constraint_map,
+                seed_events=row_seed_events,
+            )
+            acceptance_score = float(
+                score_row["self_deciding_frontier_generation_score"]
+            )
+            if acceptance_score > threshold:
+                row_frontier.append((acceptance_score, event))
+        row_frontier.sort(
+            key=lambda item: (
+                -item[0],
+                item[1].segment_a_start,
+                item[1].segment_b_start,
+                item[1].event_id,
+            )
+        )
+        if len(row_frontier) > len(row_seed_events) * min_growth_ratio:
+            selected.extend(event for _score, event in row_frontier)
+        else:
+            selected.extend(row_seed_events)
+    return tuple(selected)
+
+
 def _self_deciding_frontier_expansion_score(
     event: NucleusClosureEvent,
     context: CouplingNucleusContext,
