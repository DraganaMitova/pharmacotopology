export REPO_ROOT="/Users/draganamitova/My Projects/pharmacotopology"
cd "$REPO_ROOT" || exit 1

cat > .gitignore <<'EOF'
# ----------------------------
# OS / editor noise
# ----------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ----------------------------
# Python noise
# ----------------------------
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.ipynb_checkpoints/

# ----------------------------
# Environments / installs
# ----------------------------
.venv/
venv/
env/
ENV/
site/
dist/
build/
*.egg-info/

# ----------------------------
# Local rescue / scratch / temp
# ----------------------------
_local_rescue_*/
tmp/
temp/
scratch/
*.tmp
*.bak
*.backup

# ----------------------------
# Logs
# ----------------------------
*.log

# ----------------------------
# KEEP SOURCE DATA TRACKED
# ----------------------------
!data/
!data/**
!data/locked_runtime_certificates/
!data/locked_runtime_certificates/**

# ----------------------------
# KEEP CODE / TESTS / DOCS TRACKED
# ----------------------------
!src/
!src/**
!scripts/
!scripts/**
!tests/
!tests/**
!docs/
!docs/**
!README*
!*.md

# ----------------------------
# Runtime output policy
# ----------------------------
first_contact_clean_pharmacotopology_layer_run/*
!first_contact_clean_pharmacotopology_layer_run/**/

!first_contact_clean_pharmacotopology_layer_run/**/*.json
!first_contact_clean_pharmacotopology_layer_run/**/*.csv
!first_contact_clean_pharmacotopology_layer_run/**/*.md
!first_contact_clean_pharmacotopology_layer_run/**/*.txt

first_contact_clean_pharmacotopology_layer_run/**/*.pdb
first_contact_clean_pharmacotopology_layer_run/**/*.pdb.gz
first_contact_clean_pharmacotopology_layer_run/**/*.xtc
first_contact_clean_pharmacotopology_layer_run/**/*.dcd
first_contact_clean_pharmacotopology_layer_run/**/*.trr
first_contact_clean_pharmacotopology_layer_run/**/*.nc
first_contact_clean_pharmacotopology_layer_run/**/*.h5
first_contact_clean_pharmacotopology_layer_run/**/*.hdf5
first_contact_clean_pharmacotopology_layer_run/**/*.npy
first_contact_clean_pharmacotopology_layer_run/**/*.npz
first_contact_clean_pharmacotopology_layer_run/**/*.pkl
first_contact_clean_pharmacotopology_layer_run/**/*.pickle

first_contact_clean_pharmacotopology_layer_run/**/*.png
first_contact_clean_pharmacotopology_layer_run/**/*.jpg
first_contact_clean_pharmacotopology_layer_run/**/*.jpeg
first_contact_clean_pharmacotopology_layer_run/**/*.gif
first_contact_clean_pharmacotopology_layer_run/**/*.mp4
first_contact_clean_pharmacotopology_layer_run/**/*.mov
first_contact_clean_pharmacotopology_layer_run/**/*.svg
first_contact_clean_pharmacotopology_layer_run/**/*.html

!first_contact_clean_pharmacotopology_layer_run/**/certificate*.json
!first_contact_clean_pharmacotopology_layer_run/**/*certificate*.json
!first_contact_clean_pharmacotopology_layer_run/**/*report*.md
!first_contact_clean_pharmacotopology_layer_run/**/*table*.csv

# ----------------------------
# Downloaded target structures are reproducibility material
# ----------------------------
!data/v16_pressure_targets/
!data/v16_pressure_targets/**

# ----------------------------
# KEEP independent target/source structures
# These are source/provenance material, not disposable runtime output.
# ----------------------------
!data/
!data/**
!data/independent_contact_sources/
!data/independent_contact_sources/**
!data/independent_contact_sources/**/*.pdb
!data/independent_contact_sources/**/*.pdb.gz
!data/independent_contact_sources/**/*.json
!data/independent_contact_sources/**/*.txt
!data/independent_contact_sources/**/*.fasta

# ----------------------------
# Large archives
# ----------------------------
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar
EOF